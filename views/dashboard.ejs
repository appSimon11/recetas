<%- include("partials/page-start") %>

<section class="kitchen-hero">
  <div>
    <p class="eyebrow">Mesa Viva</p>
    <h1>Tu cocina, ordenada por antojo e ingredientes.</h1>
    <form class="hero-search" method="get" action="/despensa">
      <input name="ingredientes" placeholder="Ej. pollo, arroz, jitomate, limon">
      <button type="submit">Ver que puedo cocinar</button>
    </form>
  </div>
  <div class="hero-plate">
    <% if (dashboard.recent.length) { %>
      <img src="/recetas/<%= dashboard.recent[0].id %>/imagen?v=<%= new Date(dashboard.recent[0].updated_at || Date.now()).getTime() %>" alt="<%= dashboard.recent[0].title %>">
      <span><%= dashboard.recent[0].title %></span>
    <% } else { %>
      <img src="/recetas/0/imagen" alt="Plato">
      <span>Empieza con tu primera receta</span>
    <% } %>
  </div>
</section>

<section class="metrics">
  <article>
    <span>Recetas</span>
    <strong><%= dashboard.summary.recipe_count || 0 %></strong>
  </article>
  <article>
    <span>Ingredientes</span>
    <strong><%= dashboard.summary.ingredient_count || 0 %></strong>
  </article>
  <article>
    <span>Cocinas</span>
    <strong><%= dashboard.summary.cuisine_count || 0 %></strong>
  </article>
</section>

<section class="section-head">
  <div>
    <p class="eyebrow">Recientes</p>
    <h2>Ultimas recetas</h2>
  </div>
  <a href="/recetas">Ver recetario</a>
</section>

<section class="recipe-grid">
  <% if (!dashboard.recent.length) { %>
    <div class="empty">Todavia no hay recetas guardadas.</div>
  <% } %>
  <% dashboard.recent.forEach((recipe) => { %>
    <a class="recipe-card" href="/recetas/<%= recipe.id %>">
      <img src="/recetas/<%= recipe.id %>/imagen?v=<%= new Date(recipe.updated_at || Date.now()).getTime() %>" alt="<%= recipe.title %>">
      <div>
        <span><%= recipe.category || recipe.cuisine || "Receta" %></span>
        <h3><%= recipe.title %></h3>
        <p><%= recipe.ingredient_summary || "Sin ingredientes capturados" %></p>
      </div>
    </a>
  <% }) %>
</section>

<% if (dashboard.tags.length) { %>
  <section class="tag-cloud">
    <% dashboard.tags.forEach((tag) => { %>
      <a href="/recetas?q=<%= encodeURIComponent(tag.tag) %>"><%= tag.tag %></a>
    <% }) %>
  </section>
<% } %>

<%- include("partials/page-end") %>
