<%- include("../partials/page-start") %>

<section class="recipe-show">
  <div class="show-media">
    <img src="/recetas/<%= recipe.id %>/imagen" alt="<%= recipe.title %>">
  </div>

  <article class="show-body">
    <div class="show-actions">
      <a class="button" href="/recetas">Volver</a>
      <a class="button primary" href="/recetas/<%= recipe.id %>/editar">Editar</a>
    </div>
    <p class="eyebrow"><%= recipe.category || "Receta" %></p>
    <h1><%= recipe.title %></h1>
    <% if (recipe.subtitle) { %><p class="subtitle"><%= recipe.subtitle %></p><% } %>

    <div class="meta-row">
      <span><%= recipe.prep_minutes %> min</span>
      <span><%= recipe.servings %> porciones</span>
      <span><%= recipe.difficulty %></span>
      <% if (recipe.cuisine) { %><span><%= recipe.cuisine %></span><% } %>
    </div>

    <% if (recipe.tags.length) { %>
      <div class="chips">
        <% recipe.tags.forEach((tag) => { %><span><%= tag %></span><% }) %>
      </div>
    <% } %>

    <section>
      <h2>Ingredientes</h2>
      <ul class="ingredients-list">
        <% recipe.ingredients.forEach((ingredient) => { %>
          <li>
            <strong><%= ingredient.name %></strong>
            <span><%= [ingredient.quantity, ingredient.unit].filter(Boolean).join(" ") %></span>
          </li>
        <% }) %>
      </ul>
    </section>

    <section>
      <h2>Preparacion</h2>
      <div class="instructions"><%= recipe.instructions || "Sin pasos capturados todavia." %></div>
    </section>
  </article>
</section>

<%- include("../partials/page-end") %>
