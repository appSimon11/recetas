<%- include("../partials/page-start") %>

<section class="page-title">
  <div>
    <p class="eyebrow">Recetas</p>
    <h1>Carga por lote</h1>
  </div>
  <a class="button" href="/recetas">Recetas</a>
</section>

<section class="batch-layout">
  <article class="batch-guide">
    <p class="eyebrow">Formato</p>
    <h2>Una receta por renglon</h2>
    <p>El layout trae instrucciones arriba. La app ignora los primeros 4 renglones y empieza a leer recetas desde el renglon 5.</p>
    <p>Usa columnas separadas para cada ingrediente: ingrediente 1, cantidad 1, unidad 1, ingrediente 2, cantidad 2, unidad 2.</p>
    <div class="sample-box">
      <code>Renglon 3: Las recetas empiezan en el renglon 5.</code>
      <code>Renglon 4: encabezados.</code>
      <code>Renglon 5: primera receta.</code>
    </div>
    <div class="batch-actions">
      <button class="button" id="fillBatchSample" type="button">Usar muestra</button>
      <button class="button" id="downloadBatchTemplate" type="button">Bajar layout</button>
    </div>
  </article>

  <form class="bulk-form" method="post" action="/recetas/lote/preview">
    <label>
      Pega tus recetas
      <textarea id="batchText" name="batch_text" rows="16" placeholder="Baja el layout o usa la muestra para empezar"><%= batchText %></textarea>
    </label>
    <button class="button primary" type="submit">Previsualizar</button>
  </form>
</section>

<% if (errors.length) { %>
  <section class="notice danger">
    <% errors.forEach((error) => { %>
      <div><%= error %></div>
    <% }) %>
  </section>
<% } %>

<% if (preview) { %>
  <section class="preview-section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Revision</p>
        <h2><%= preview.length %> recetas detectadas</h2>
      </div>
      <% if (!errors.length && preview.length) { %>
        <form method="post" action="/recetas/lote">
          <textarea name="batch_text" hidden><%= batchText %></textarea>
          <button class="button primary" type="submit">Cargar recetas</button>
        </form>
      <% } %>
    </div>

    <% if (!preview.length) { %>
      <div class="empty">No hay recetas para previsualizar todavia.</div>
    <% } %>

    <div class="preview-table">
      <% preview.forEach((recipe) => { %>
        <article class="preview-card">
          <div>
            <span>Renglon <%= recipe.rowNumber %></span>
            <h3><%= recipe.title %></h3>
            <p><%= [recipe.category, recipe.cuisine, `${recipe.prep_minutes} min`, `${recipe.servings} porciones`].filter(Boolean).join(" · ") %></p>
          </div>
          <div>
            <strong>Ingredientes</strong>
            <p><%= recipe.ingredients.map((item) => [item.name, item.quantity, item.unit].filter(Boolean).join(" ")).join(", ") || "-" %></p>
          </div>
          <div>
            <strong>Preparacion</strong>
            <p><%= recipe.instructions || "-" %></p>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
<% } %>

<script src="/recipe-batch.js"></script>

<%- include("../partials/page-end") %>
